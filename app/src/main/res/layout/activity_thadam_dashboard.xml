<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="THADAM C3 TRUST"
                android:textColor="#E6EDF3"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefresh"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="SCAN"
                android:textColor="#58A6FF"
                app:strokeColor="#30363D" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="DOCS"
                android:textColor="#8B949E" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeToggle"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:text="☀"
                android:textColor="#8B949E"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Global Trust Score Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GLOBAL TRUST LEVEL"
                    android:textColor="#8B949E"
                    android:textSize="11sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tvTrustLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EVALUATING..."
                    android:textColor="#FFC107"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:paddingTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CIA Score"
                        android:textColor="#8B949E"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvGlobalScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#E6EDF3"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Trust bar -->
                <ProgressBar
                    android:id="@+id/progressTrust"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/trust_progress" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp">

                    <TextView
                        android:id="@+id/tvChainFloor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chain: —"
                        android:textColor="#8B949E"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvLastScan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last: —"
                        android:textColor="#8B949E"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Device Info Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDeviceInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEVICE PROFILE"
                    android:textColor="#8B949E"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/tvDeviceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detecting..."
                    android:textColor="#E6EDF3"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDeviceDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#8B949E"
                    android:textSize="12sp"
                    android:paddingTop="4dp" />

                <TextView
                    android:id="@+id/tvSupplyChainRisk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FF9800"
                    android:textSize="11sp"
                    android:paddingTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Trust History Chart -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRUST HISTORY"
                    android:textColor="#8B949E"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:paddingBottom="8dp" />

                <com.vtmis.fedramp.thadam.ui.TrustHistoryChart
                    android:id="@+id/trustHistoryChart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CIA Breakdown -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CIA BREAKDOWN"
                    android:textColor="#8B949E"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:paddingBottom="12dp" />

                <!-- Confidentiality -->
                <include layout="@layout/item_cia_row"
                    android:id="@+id/rowConfidentiality" />

                <!-- Integrity -->
                <include layout="@layout/item_cia_row"
                    android:id="@+id/rowIntegrity" />

                <!-- Availability -->
                <include layout="@layout/item_cia_row"
                    android:id="@+id/rowAvailability" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Gate Results -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GATE CHAIN RESULTS"
            android:textColor="#8B949E"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="8dp"
            android:paddingTop="4dp" />

        <LinearLayout
            android:id="@+id/gateResultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Signal Details -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIGNAL DETAILS (22 SENSORS)"
            android:textColor="#8B949E"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="8dp"
            android:paddingTop="16dp" />

        <LinearLayout
            android:id="@+id/signalDetailsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Remediation Actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REMEDIATION ACTIONS"
            android:textColor="#8B949E"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="8dp"
            android:paddingTop="16dp" />

        <LinearLayout
            android:id="@+id/remediationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Export Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExport"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="EXPORT COMPLIANCE REPORT"
            android:textColor="#58A6FF"
            app:strokeColor="#30363D"
            app:icon="@android:drawable/ic_menu_share"
            app:iconTint="#58A6FF" />

        <!-- Audit Log Preview -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECENT AUDIT EVENTS"
                    android:textColor="#8B949E"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/tvAuditLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No events yet..."
                    android:textColor="#7D8590"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:maxLines="20" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
