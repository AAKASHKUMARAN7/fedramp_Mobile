<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#161B22"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/viewGateIndicator"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#8B949E" />

            <TextView
                android:id="@+id/tvGateName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Gate Name"
                android:textColor="#E6EDF3"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGateDecision"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALLOW"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="6dp">

            <TextView
                android:id="@+id/tvGateScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Score: 0.000"
                android:textColor="#7D8590"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvGateC3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="C3: [0.00, 0.00, 0.00]"
                android:textColor="#7D8590"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvGateReasons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:text=""
            android:textColor="#F0883E"
            android:textSize="10sp"
            android:visibility="gone" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
